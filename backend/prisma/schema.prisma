generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_DATABASE_URL")
}


model User {
  id       String     @id @default(uuid())
  name     String?
  email  String  @unique
  password String
  blogs    Post[]
}

model Post {
  id        String     @id @default(uuid())
  authorId  String
  content   String
  title     String
  published Boolean @default(false)
  author    User    @relation(fields: [authorId], references: [id])
}
